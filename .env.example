# auth service env. Real values live in the gateway's .env / .env.production
# (and in GH Actions Secrets for production deploys). This file documents the
# required keys; it is not loaded directly.

# Google OAuth 2.0 web-application client.
# Authorized redirect URIs to register in Cloud Console:
#   - https://auth.rndexp.art/auth/google/callback
#   - https://auth.rndexp.localhost/auth/google/callback
AUTH_GOOGLE_CLIENT_ID=
AUTH_GOOGLE_CLIENT_SECRET=

# 32+ byte random string. Sign cookie + OAuth state tokens.
# Generate: `python -c "import secrets; print(secrets.token_urlsafe(48))"`
AUTH_JWT_SECRET=

# This email is granted the `admin` role automatically on first login.
AUTH_INITIAL_ADMIN_EMAIL=
